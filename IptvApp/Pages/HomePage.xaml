<Page
    x:Class="IptvApp.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:IptvApp.Pages"
    xmlns:controls="using:IptvApp.Controls"
    xmlns:models="using:IptvApp.Core.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="F11" Invoked="FullscreenAccelerator_Invoked" />
        <KeyboardAccelerator Key="Escape" Invoked="EscapeAccelerator_Invoked" />
    </Page.KeyboardAccelerators>

    <Grid x:Name="MainGrid" Background="Transparent" Padding="24,16,24,16" RowSpacing="16" PointerMoved="MainGrid_PointerMoved">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Notification InfoBar -->
        <InfoBar Grid.Row="0"
                 x:Name="NotificationInfoBar"
                 Message="{x:Bind ViewModel.NotificationMessage, Mode=OneWay}"
                 Severity="{x:Bind ViewModel.NotificationSeverity, Mode=OneWay}"
                 IsOpen="{x:Bind ViewModel.IsNotificationOpen, Mode=TwoWay}"
                 HorizontalAlignment="Stretch" />

        <!-- Removed PageTitle to save space -->
        <Grid x:Name="ContentGrid" Grid.Row="2" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ChannelsColumn" Width="320" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="StatsColumn" Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid x:Name="ChannelsGrid" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Danh sách Kênh" />
                
                <!-- Search Bar -->
                <TextBox Grid.Row="1"
                         PlaceholderText="Tìm kiếm tên kênh hoặc nhóm..."
                         Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,4" />

                <!-- Categories ComboBox -->
                <ComboBox Grid.Row="2"
                          ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          HorizontalAlignment="Stretch"
                          Margin="0,0,0,8" />

                <ListView
                    x:Name="ChannelsList"
                    Grid.Row="3"
                    ItemsSource="{x:Bind ViewModel.Channels, Mode=OneWay}"
                    SelectionChanged="ChannelsList_SelectionChanged"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="{ThemeResource LayerFillColorDefaultBrush}">
                    
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Margin" Value="0,2,0,2" />
                            <Setter Property="Padding" Value="8,6,8,6" />
                            <Setter Property="CornerRadius" Value="8" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Channel">
                            <Grid Margin="4,4,4,4" ColumnSpacing="12" PointerEntered="ChannelItem_PointerEntered">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                
                                <Border Width="40" Height="40" CornerRadius="4" Background="{ThemeResource SystemControlBackgroundAltMediumBrush}">
                                    <Image Source="{x:Bind local:HomePage.GetImageSource(LogoUrl), Mode=OneTime}" Stretch="UniformToFill" />
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Name, Mode=OneTime}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{x:Bind GroupName, Mode=OneTime}" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <!-- Favorite Button -->
                                <Button Grid.Column="2" 
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        Padding="4"
                                        Click="FavoriteButton_Click"
                                        ToolTipService.ToolTip="Thêm vào yêu thích">
                                    <FontIcon Glyph="{x:Bind local:HomePage.GetFavoriteGlyph(IsFavorite), Mode=OneWay}" 
                                              Foreground="Gold" 
                                              FontSize="14" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Grid Grid.Column="1" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition x:Name="MetadataRow" Height="Auto" />
                </Grid.RowDefinitions>

                <Border x:Name="PlayerBorder" CornerRadius="12" Background="Black" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <Grid x:Name="PlayerContainer"
                          DoubleTapped="PlayerContainer_DoubleTapped"
                          Background="Transparent">
                        <controls:MpvPlayer x:Name="Player" />

                        <!-- Loading Overlay inside Player -->
                        <Grid Background="#D0000000" Visibility="{x:Bind GetVisibility(ViewModel.IsPlayerLoading), Mode=OneWay}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                                <ProgressRing IsActive="True" Width="36" Height="36" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                <TextBlock Text="Đang tải luồng phát..." Foreground="White" FontSize="12" FontWeight="SemiBold" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Grid x:Name="MetadataPanel" Grid.Row="1" RowSpacing="8" Margin="8,4,8,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <!-- Title & Control Buttons -->
                    <Grid Grid.Row="0" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Text="{x:Bind ViewModel.PlayingChannelName, Mode=OneWay}" 
                                   FontWeight="Bold" 
                                   FontSize="16" 
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}" 
                                   TextTrimming="CharacterEllipsis"/>
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button Click="PlayButton_Click" ToolTipService.ToolTip="Tạm dừng / Tiếp tục" Width="36" Height="36" Padding="0" CornerRadius="18">
                                <FontIcon Glyph="&#xE768;" FontSize="14" />
                            </Button>
                            <Button Click="StopButton_Click" ToolTipService.ToolTip="Dừng phát" Width="36" Height="36" Padding="0" CornerRadius="18">
                                <FontIcon Glyph="&#xE71A;" FontSize="14" />
                            </Button>
                            <Button Click="StatsButton_Click" ToolTipService.ToolTip="Thông số luồng phát (Ctrl+I)" Width="36" Height="36" Padding="0" CornerRadius="18">
                                <FontIcon Glyph="&#xE946;" FontSize="14" />
                            </Button>
                            <!-- AI Shader Switcher (Segmented Control) -->
                            <StackPanel Orientation="Horizontal" Spacing="4" 
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                        Padding="4" 
                                        CornerRadius="20"
                                        BorderThickness="1"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        ToolTipService.ToolTip="Bộ lọc AI (Tắt / Sắc nét / Kích thước 4K)">
                                <ToggleButton Content="OFF" 
                                              IsChecked="{x:Bind ViewModel.IsShaderNone, Mode=OneWay}" 
                                              Command="{x:Bind ViewModel.SetShaderCommand}" CommandParameter="None" 
                                              CornerRadius="16" Height="32" FontWeight="SemiBold" />
                                <ToggleButton Content="CAS (Sharp)" 
                                              IsChecked="{x:Bind ViewModel.IsShaderCas, Mode=OneWay}" 
                                              Command="{x:Bind ViewModel.SetShaderCommand}" CommandParameter="CAS" 
                                              CornerRadius="16" Height="32" FontWeight="SemiBold" />
                                <ToggleButton Content="FSRCNNX (4K)" 
                                              IsChecked="{x:Bind ViewModel.IsShaderFsrcnnx, Mode=OneWay}" 
                                              Command="{x:Bind ViewModel.SetShaderCommand}" CommandParameter="FSRCNNX" 
                                              CornerRadius="16" Height="32" FontWeight="SemiBold" />
                            </StackPanel>
                            <ComboBox ItemsSource="{x:Bind ViewModel.ContentProfiles, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedProfile, Mode=TwoWay}"
                                      Width="130"
                                      Height="36"
                                      CornerRadius="18"
                                      ToolTipService.ToolTip="Chế độ hiển thị (Tự động / Tin tức / Thể thao / Phim / Anime / Tài liệu)">
                            </ComboBox>
                            <Button Click="FullscreenButton_Click" ToolTipService.ToolTip="Toàn màn hình (F11)" Width="36" Height="36" Padding="0" CornerRadius="18">
                                <FontIcon Glyph="&#xE740;" FontSize="14" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Stats Sidebar -->
            <Border Grid.Column="2"
                    x:Name="StatsSidebar"
                    Width="300"
                    Visibility="{x:Bind GetVisibility(ViewModel.ShowStats), Mode=OneWay}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,0,12">
                <Grid RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Thông số kỹ thuật" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold" />
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Trạng thái luồng" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsConnectionStatus, Mode=OneWay}" FontWeight="Bold" FontSize="14" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Trạng thái dòng real-time" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsStreamStatus, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Độ phân giải" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsResolution, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>
                            
                            <StackPanel Spacing="2">
                                <TextBlock Text="Tốc độ khung hình (FPS)" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsFps, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Tần số quét màn hình" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsDisplayFps, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>
                            
                            <StackPanel Spacing="2">
                                <TextBlock Text="Mã hóa Video" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsVideoCodec, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>
                            
                            <StackPanel Spacing="2">
                                <TextBlock Text="Giải mã phần cứng" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsHwdec, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Định dạng màu Pixel" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsPixelFormat, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Khử quét xen kẽ" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsDeinterlace, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Khử vỡ khối màu (Deband)" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsDeband, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Trạng thái HDR" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsHdrStatus, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>
                            
                            <StackPanel Spacing="2">
                                <TextBlock Text="Mã hóa Âm thanh" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsAudioCodec, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>
                            
                            <StackPanel Spacing="2">
                                <TextBlock Text="Kênh âm thanh" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsAudioChannels, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>
                            
                            <StackPanel Spacing="2">
                                <TextBlock Text="Tần số lấy mẫu" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsAudioSampleRate, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>
                            
                            <StackPanel Spacing="2">
                                <TextBlock Text="Khung hình bị trễ" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsDroppedFrames, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Trễ hiển thị (VO Delayed)" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsVoDelayed, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Độ trễ Live Edge" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsLiveLatency, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>
                            
                            <StackPanel Spacing="2">
                                <TextBlock Text="Packet Loss (Mạng)" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsPacketLoss, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>
                            
                            <StackPanel Spacing="2">
                                <TextBlock Text="Bộ đệm Demuxer" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsCacheState, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Màu sắc (Bit Depth / Matrix / Range / Primaries)" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap">
                                    <Run Text="{x:Bind ViewModel.StatsBitDepth, Mode=OneWay}" />
                                    <Run Text=" / " />
                                    <Run Text="{x:Bind ViewModel.StatsColorMatrix, Mode=OneWay}" />
                                    <Run Text=" / " />
                                    <Run Text="{x:Bind ViewModel.StatsColorRange, Mode=OneWay}" />
                                    <Run Text=" / " />
                                    <Run Text="{x:Bind ViewModel.StatsColorPrimaries, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Mạng (Tốc độ / Chi tiết Bitrate)" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap">
                                    <Run Text="{x:Bind ViewModel.StatsNetworkSpeed, Mode=OneWay}" />
                                    <Run Text="&#x0a;Bitrate: " />
                                    <Run Text="{x:Bind ViewModel.StatsRealTimeBitrate, Mode=OneWay}" />
                                    <Run Text=" (" />
                                    <Run Text="{x:Bind ViewModel.StatsBitrateDetails, Mode=OneWay}" />
                                    <Run Text=")" />
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Shader AI đang chạy" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsActiveShaders, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Hiệu năng GPU (Render Time/Jitter)" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsGpuRenderTime, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Đồng bộ A/V (Lệch Audio/Video)" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsAvSync, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="GPU đang kết xuất (Active Rendering)" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsActiveGpu, Mode=OneWay}" FontWeight="Bold" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" />
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="GPU hệ thống khả dụng" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                <TextBlock Text="{x:Bind ViewModel.StatsGpuName, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.RowSpan="2" Background="#80000000" Visibility="{x:Bind GetVisibility(ViewModel.IsLoading), Mode=OneWay}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <ProgressRing IsActive="True" Width="48" Height="48" Foreground="White" />
                <TextBlock Text="Đang xử lý..." Foreground="White" FontWeight="SemiBold" />
            </StackPanel>
        </Grid>

        <Button x:Name="FullscreenExitButton"
                Grid.RowSpan="3"
                Click="FullscreenButton_Click" 
                Background="#B31A1A1A" 
                BorderBrush="#33FFFFFF" 
                Foreground="White" 
                Width="48" 
                Height="48" 
                CornerRadius="24"
                Margin="0,0,32,32"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Visibility="Collapsed">
            <FontIcon Glyph="&#xE73F;" FontSize="18" />
        </Button>
    </Grid>
</Page>
