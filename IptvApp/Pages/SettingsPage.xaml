<Page
    x:Class="IptvApp.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:IptvApp.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,16">
        <StackPanel Spacing="24" MaxWidth="800" HorizontalAlignment="Left">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Cài đặt hệ thống" />

            <!-- Notification InfoBar -->
            <InfoBar x:Name="NotificationInfoBar"
                     Message="{x:Bind ViewModel.NotificationMessage, Mode=OneWay}"
                     Severity="{x:Bind ViewModel.NotificationSeverity, Mode=OneWay}"
                     IsOpen="{x:Bind ViewModel.IsNotificationOpen, Mode=TwoWay}"
                     HorizontalAlignment="Stretch" />
            
            <!-- Card 1: Playlist M3U -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    HorizontalAlignment="Stretch">
                <StackPanel Spacing="12">
                    <TextBlock Text="Cấu hình Danh sách phát (M3U)" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Nhập đường dẫn URL hoặc đường dẫn tệp tin nội bộ chứa danh sách phát của bạn." 
                               FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                    <Grid ColumnSpacing="12" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox PlaceholderText="Nhập URL M3U8 hoặc đường dẫn file .m3u..."
                                 Text="{x:Bind ViewModel.PlaylistUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1" Click="BrowsePlaylist_Click" ToolTipService.ToolTip="Duyệt thư mục">
                            <FontIcon Glyph="&#xED25;" FontSize="14" />
                        </Button>
                        <Button Grid.Column="2" 
                                Content="Nạp Danh sách" 
                                Command="{x:Bind ViewModel.ImportPlaylistCommand}" 
                                Style="{StaticResource AccentButtonStyle}" />
                    </Grid>
                </StackPanel>
            </Border>


            <!-- Loading Indicator -->
            <StackPanel Orientation="Horizontal" Spacing="12" Visibility="{x:Bind GetVisibility(ViewModel.IsLoading), Mode=OneWay}" Margin="0,8,0,0">
                <ProgressRing IsActive="True" Width="20" Height="20" />
                <TextBlock Text="Đang xử lý nạp dữ liệu..." VerticalAlignment="Center" FontSize="13" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
